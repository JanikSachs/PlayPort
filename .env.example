# Server Configuration
SERVER_ADDR=:8080

# Spotify OAuth Configuration
# To enable Spotify integration, set the following variables:
# 1. Create an app at https://developer.spotify.com/dashboard
# 2. Copy your Client ID and Client Secret
# 3. Add the redirect URL to your app settings

# Your Spotify App Client ID
SPOTIFY_CLIENT_ID=

# Your Spotify App Client Secret
SPOTIFY_CLIENT_SECRET=

# OAuth Redirect URL (must match the one in your Spotify app settings)
# For local development:
SPOTIFY_REDIRECT_URL=http://localhost:8080/auth/spotify/callback
# For production:
# SPOTIFY_REDIRECT_URL=https://yourdomain.com/auth/spotify/callback

# YouTube Music OAuth Configuration
# To enable YouTube Music integration, set the following variables:
# 1. Create a project at https://console.cloud.google.com/
# 2. Enable the YouTube Data API v3
# 3. Create OAuth 2.0 credentials (Web application type)
# 4. Add the redirect URL to your authorized redirect URIs

# Your Google OAuth Client ID
YOUTUBE_MUSIC_CLIENT_ID=

# Your Google OAuth Client Secret
YOUTUBE_MUSIC_CLIENT_SECRET=

# OAuth Redirect URL (must match the one in your Google Cloud Console)
# For local development:
YOUTUBE_MUSIC_REDIRECT_URL=http://localhost:8080/auth/youtubemusic/callback
# For production:
# YOUTUBE_MUSIC_REDIRECT_URL=https://yourdomain.com/auth/youtubemusic/callback
